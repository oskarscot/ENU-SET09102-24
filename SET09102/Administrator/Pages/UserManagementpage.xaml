<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SET09102.Administrator.Pages.UserManagementPage"
             Title="User Management">
    <VerticalStackLayout Padding="20">
        <!-- Add User Section -->
        <Label Text="Add New User" FontSize="Large" FontAttributes="Bold" />
        <Entry Placeholder="Enter Username"
               Text="{Binding NewUsername, Mode=TwoWay}" />
        <Picker Title="Select Role"
                ItemsSource="{Binding Roles}"
                ItemDisplayBinding="{Binding Name}"
                SelectedItem="{Binding NewRole, Mode=TwoWay}" />
        <Button Text="Add User"
                Command="{Binding AddUserCommand}" />

        <!-- User List Section -->
        <Label Text="Users" FontSize="Large" FontAttributes="Bold" Margin="0,20,0,0" />
        <ListView ItemsSource="{Binding Users}"
                  HasUnevenRows="True">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <HorizontalStackLayout Padding="10">
                            <Label Text="{Binding Username}" FontSize="Medium" VerticalOptions="Center" />
                            <Label Text="{Binding RoleId, StringFormat='Role ID: {0}'}" FontSize="Small" VerticalOptions="Center" Margin="10,0,0,0" />
                        </HorizontalStackLayout>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </VerticalStackLayout>
</ContentPage>